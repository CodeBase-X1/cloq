{
  "name": "cloq",
  "displayName": "Cloq - Local LLM Context Sanitizer",
  "description": "Intercepts, sanitizes, and caches your LLM prompts before they leave your machine.",
  "version": "0.1.0",
  "publisher": "AbdulNazeer",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeBase-X1/cloq"
  },
  "homepage": "https://github.com/CodeBase-X1/cloq",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cloq.startProxy",
        "title": "Cloq: Start Local Proxy"
      },
      {
        "command": "cloq.openDashboard",
        "title": "Cloq: Open Web Dashboard"
      }
    ],
    "configuration": {
      "title": "Cloq",
      "properties": {
        "cloq.cliCommand": {
          "type": "string",
          "default": "cloq-cli",
          "description": "The command to run the Cloq CLI. You may need to provide the full path to the executable if it is not in your PATH."
        },
        "cloq.proxyPort": {
          "type": "number",
          "default": 8989,
          "description": "Port for the Cloq proxy server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "esbuild": "^0.18.11"
  }
}
